PORT=8080
DATABASE_URL=postgres://cornerlab:cornerlab@postgres:5432/cornerlab?sslmode=disable
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
JWT_SECRET=change-me-in-production
ENVIRONMENT=development

# Módulo de Inteligência Estatística — explicações via IA (Anthropic Messages API).
# Sem esta chave, o endpoint POST /api/v1/intelligence/explain responde 503 com uma
# mensagem clara em vez de quebrar o restante da aplicação.
ANTHROPIC_API_KEY=

# Sincronização com dados reais (cmd/sync). Deixe em branco para continuar usando
# apenas os dados de exemplo gerados por cmd/seed.
# SPORTS_DATA_PROVIDER: api_football | sportmonks | fallback (tenta os dois, nessa ordem)
SPORTS_DATA_PROVIDER=fallback
API_FOOTBALL_KEY=
SPORTMONKS_KEY=
