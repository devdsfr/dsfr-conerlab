PORT=8080
DATABASE_URL=postgres://cornerlab:cornerlab@postgres:5432/cornerlab?sslmode=disable
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
JWT_SECRET=change-me-in-production
ENVIRONMENT=development

# Módulo de Inteligência Estatística — explicações via IA (OpenAI Chat Completions API).
# Sem esta chave, o endpoint POST /api/v1/intelligence/explain responde 503 com uma
# mensagem clara em vez de quebrar o restante da aplicação.
OPENAI_API_KEY=

# Sincronização com dados reais (cmd/sync). Deixe em branco para continuar usando
# apenas os dados de exemplo gerados por cmd/seed.
# SPORTS_DATA_PROVIDER: api_football | sportmonks | fallback (tenta os dois, nessa ordem)
SPORTS_DATA_PROVIDER=fallback
API_FOOTBALL_KEY=
SPORTMONKS_KEY=

# Módulo de Sincronização de Dados (cmd/worker) — processo separado que mantém o
# Postgres continuamente atualizado em background (descoberta de jogos, atualização de
# resultados, health check do provedor). Diferente de SPORTS_DATA_PROVIDER acima
# (usado só pelo cmd/sync manual).
# STATISTICS_PROVIDER: api_football (padrão, real) | sofascore (esqueleto pronto, sem
# integração real ainda — não tem API oficial, ver internal/integration/statsprovider/sofascore)
STATISTICS_PROVIDER=api_football

# Assinatura Premium (Stripe Checkout hospedado + Billing Portal + webhooks).
# Sem STRIPE_SECRET_KEY, os endpoints /api/v1/billing/* respondem 503 com mensagem
# clara em vez de quebrar o restante da aplicação — o app continua funcionando
# normalmente nos módulos gratuitos.
# 1. Crie um produto recorrente no Stripe Dashboard (ex.: R$ 29,90/mês) e copie o
#    Price ID para STRIPE_PRICE_ID.
# 2. Copie a Secret Key (modo teste ou produção) para STRIPE_SECRET_KEY.
# 3. Configure um endpoint de webhook apontando para
#    <sua-api>/api/v1/billing/webhook, escute os eventos
#    checkout.session.completed, customer.subscription.updated e
#    customer.subscription.deleted, e copie o Signing Secret para
#    STRIPE_WEBHOOK_SECRET.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_TRIAL_DAYS=7

# URL pública do frontend — usada para montar as URLs de sucesso/cancelamento do
# Stripe Checkout e de retorno do Billing Portal.
FRONTEND_URL=http://localhost:4200

# Libera acesso Premium manualmente para e-mails específicos, sem depender do
# Stripe — útil para testar/demonstrar as telas premium (Gestão de Banca,
# Projeções, Alertas, Exportações) antes da assinatura real estar configurada, ou
# para o próprio time ter uma conta de teste. Lista separada por vírgula. Uso
# apenas interno/QA — nunca para liberar acesso a clientes reais.
DEV_PREMIUM_EMAILS=
